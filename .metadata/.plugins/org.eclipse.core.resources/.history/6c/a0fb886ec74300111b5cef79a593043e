package com.Inventory.productsheet.controller;

import java.util.List;
import java.util.Optional;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.*;

import com.Inventory.productsheet.model.InventoryItem;
import com.Inventory.productsheet.model.InventoryOrder;
import com.Inventory.productsheet.repository.InventoryOrderRepository;
import com.Inventory.productsheet.service.InventoryService;

@Controller
public class InventoryController {

	private final InventoryService inventoryService;

	@Autowired
	private InventoryOrderRepository orderRepository; // ✅ Injected here

	public InventoryController(InventoryService inventoryService) {
		this.inventoryService = inventoryService;
	}

	// Landing page
	@GetMapping("/")
	public String index() {
		return "index";
	}

	// 🔍 Inventory dashboard - Now uses injected repo!
	@GetMapping("/inventory")
	public String inventory(Model model) {
		List<InventoryOrder> orders = orderRepository.findAll();

		// ✅ Add inventory items to model — you already have them in service!
		List<InventoryItem> allItems = inventoryService.getAllItems(); // 👈 Call this!

		model.addAttribute("orders", orders);
		model.addAttribute("inventoryItems", allItems); // 🔥 NEW LINE
		return "inventory";
	}

	// Add ingredient
	@PostMapping("/inventory/add")
	public String addLineItem(@RequestParam String name, @RequestParam int quantity, @RequestParam String unit,
			@RequestParam int reorderLevel) {

		InventoryItem item = new InventoryItem();
		item.setName(name);
		item.setQuantity(quantity);
		item.setUnit(unit);
		item.setReorderLevel(reorderLevel);

		inventoryService.addItem(item);

		return "redirect:/inventory";
	}

	// Restock ingredient
	@PostMapping("/inventory/restock")
	public String restock(@RequestParam Long id, @RequestParam int amount) {

		if (id == null) {
			throw new IllegalArgumentException("Item ID cannot be null (restock)");
		}

		inventoryService.restockItem(id, amount);
		return "redirect:/inventory";
	}

	// Order from distributor
	@PostMapping("/inventory/order")
	public String orderItem(@RequestParam Long id, @RequestParam int amount) {

		if (id == null) {
			throw new IllegalArgumentException("Item ID cannot be null (order)");
		}

		inventoryService.orderFromDistributor(id, amount);
		return "redirect:/inventory";
	}

	// Login page
	@GetMapping("/login")
	public String login() {
		return "login";
	}

	// Mark delivered - POST only!
	@PostMapping("/orders/{id}/delivery")
	public String markDelivered(@PathVariable Long id) {
		System.out.println("✅ Received ID: " + id); // Debug line

		if (id == null || id <= 0) {
			throw new IllegalArgumentException("Order ID cannot be null or zero");
		}

		inventoryService.markOrderDelivered(id);
		return "redirect:/inventory";
	}

	@PostMapping("/orders/{id}/delete")
	public String deleteOrder(@PathVariable Long id) {
		Optional<InventoryOrder> found = orderRepository.findById(id);

		if (found.isPresent()) {
			orderRepository.delete(found.get());
		}

		return "redirect:/inventory";
	}

	@PostMapping("/inventory/update")
	public String updateStock(@RequestParam Long id, @RequestParam int quantity) {

		if (id == null) {
			throw new IllegalArgumentException("Item ID cannot be null (update)");
		}

		inventoryService.updateStock(id, quantity);
		return "redirect:/inventory";
	}
	@PostMapping("/inventory/delete")
	public String deleteInventoryItem(@RequestParam Long id) {

	    if (id == null) {
	        throw new IllegalArgumentException("Item ID cannot be null");
	    }

	    inventoryService.deleteItem(id);

	    return "redirect:/inventory";
	}

}
