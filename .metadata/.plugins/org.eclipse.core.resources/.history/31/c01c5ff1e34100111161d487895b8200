<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <title>Food Truck Inventory</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 40px;
        }
        table {
            border-collapse: collapse;
            width: 100%;
        }
        th, td {
            padding: 10px;
            border: 1px solid #ccc;
            text-align: left;
        }
        th {
            background-color: #f4f4f4;
        }
        .low-stock {
            background-color: #ffe6e6;
            color: #b00000;
            font-weight: bold;
        }
        button {
            padding: 6px 12px;
            cursor: pointer;
        }
        input[type="number"] {
            width: 70px;
        }
    </style>
</head>
<body>

<h1>Ingredient Inventory</h1>

<table>
    <thead>
        <tr>
            <th>Name</th>
            <th>Quantity</th>
            <th>Unit</th>
            <th>Reorder Level</th>
            <th>Status</th>
            <th>Restock</th>
        </tr>
    </thead>
    <tbody>
        <tr th:each="ingredient : ${ingredients}"
            th:classappend="${ingredient.quantity <= ingredient.reorderLevel} ? ' low-stock' : ''">

            <td th:text="${ingredient.name}"></td>
            <td th:text="${ingredient.quantity}"></td>
            <td th:text="${ingredient.unit}"></td>
            <td th:text="${ingredient.reorderLevel}"></td>

            <td>
                <span th:if="${ingredient.quantity <= ingredient.reorderLevel}">⚠ LOW</span>
                <span th:if="${ingredient.quantity > ingredient.reorderLevel}">OK</span>
            </td>

            <!-- ✅ Corrected form -->
            <td>
                <form th:action="@{/inventory/restock/{id}}" 
                      method="post"
                      name="amount"
                      min="1"
                      placeholder="Qty"
                      required>
                    <input type="hidden" name="id" value="${ingredient.id}" />
                    <button type="submit">Restock</button>
                </form>
            </td>
        </tr>
    </tbody>
</table>

</body>
</html>
