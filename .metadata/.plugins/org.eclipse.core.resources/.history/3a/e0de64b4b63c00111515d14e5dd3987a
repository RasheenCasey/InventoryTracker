package edu.vwcc.jdbc.repo;

import java.math.BigDecimal;
import java.util.List;

import org.springframework.jdbc.core.simple.JdbcClient;
import org.springframework.stereotype.Repository;

import edu.vwcc.jdbc.model.Purchase;

@Repository
public class PurchaseRepository {

	private final JdbcClient jdbc;

	public PurchaseRepository(JdbcClient jdbc) {
		this.jdbc = jdbc;
	}

	public int storePurchase(Purchase purchase) {
		return jdbc.sql("INSERT INTO purchase (product, price) VALUES (:product, :price)").paramSource(purchase)
				.update();
	}

	public List<Purchase> findAllPurchases() {
		return jdbc.sql("SELECT * FROM purchase").query(Purchase.class).list();
	}

	// Write Your Additional Repository Methods Here

	public int countPurchases() {
		return jdbc.sql("SELECT COUNT(*) FROM purchase").query(Integer.class).single();
	}

	public BigDecimal getTotalRevenue() {
		return jdbc.sql("SELECT SUM(price) FROM purchase").query(BigDecimal.class).single();

	}

	public BigDecimal getAvgPurchasePrice() {
		return jdbc.sql("SELECT AVG(price) FROM purchase").query(BigDecimal.class).single();
	}

	public Purchase findPurchaseById(int id) {
		return jdbc.sql("SELECT * FROM purchase WHERE id = :id").param("id", id).query(Purchase.class).optional()
				.orElse(null);
	}
	
	public void deletePurchaseById(int id) {
		jdbc.sql("DELETE FROM purchase WHERE id = :id").param("id",id).update();
	}
	
	public void updatePurchaseToNoCost(int id) {
		jdbc.sql("UPDATE purchase SET price = 0 WHERE id = :id").param("id",id).update();
	}
	

}