<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
<title>Food Truck Inventory</title>
<style>
body {
	font-family: Arial, sans-serif;
	margin: 40px;
}

table {
	border-collapse: collapse;
	width: 100%;
}

th, td {
	padding: 10px;
	border: 1px solid #ccc;
	text-align: left;
}

th {
	background-color: #f4f6f8;
}

.low-stock {
	background-color: #ffe6e6;
	color: #b00000;
	font-weight: bold;
}

button {
	padding: 6px 12px;
	cursor: pointer;
}

input[type="number"] {
	width: 70px;
	margin-right: 8px;
}
</style>
</head>
<body>

	<h1>Ingredient Inventory</h1>

	<table>
		<thead>
			<tr>
				<th>Name</th>
				<th>Quantity</th>
				<th>Unit</th>
				<th>Reorder Level</th>
				<th>Status</th>
				<th>Restock</th>
			</tr>
		</thead>
		<tbody>
			<!-- Example: Replace with your actual data -->
			<tr th:each="ingredient : ${ingredients}">
				<td th:text="${ingredient.name}"></td>
				<td th:text="${ingredient.quantity}"></td>
				<td th:text="${ingredient.unit}"></td>
				<td th:text="${ingredient.reorderLevel}"></td>

				<!-- Status -->
				<td><span
					th:if="${ingredient.quantity <= ingredient.reorderLevel}">⚠
						LOW</span> <span th:if="${ingredient.quantity > ingredient.reorderLevel}">OK</span>
				</td>

				<!-- ✅ CORRECTED ACTION URL & METHOD -->
				<!-- ✅ FINAL CORRECTED FORM -->
				<td>
					<form th:action="@{/inventory/restock(id=${ingredient.id})}"
						method="post" name="amountForm" class="restock-form">
						<input type="hidden" name="id" value="${ingredient.id}" /> <label
							for="amount">Qty:</label> <input type="number" id="amount"
							name="amount" min="1" placeholder="Qty" required
							th:value="${ingredient.quantity}">
						<button type="submit">Add</button>
					</form>

				</td>


			</tr>
		</tbody>
	</table>



</body>
</html>
